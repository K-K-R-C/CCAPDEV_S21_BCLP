<!DOCTYPE html>
<html>
<head>
    <title>Edit Comment - GunitaPH</title>
    <link rel="icon" href="/images/gunita-logo.png" type="image/png">

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/forms.css">
</head>
<body>
<div class="container">

    <!-- Left Sidebar -->
    {{#if user}}
    <div class="left-sidebar">
        <div class="logo">
            <h1 class="name"><span>G</span>UNITA</h1>
        </div>

        <img src="{{user.profilePic}}" class="profile-pic" alt="Profile Pic">
        <h2><a href="/user/{{user.username}}" class="profile-link">{{user.displayname}}</a></h2>
        <p>@{{user.username}}</p>

        <button>
            <a href="/" class="sidebar-btn">
                <img src="/images/home-button.png" class="home-button"> Home
            </a>
        </button>
    </div>
    {{else}}
    <div class="left-sidebar">
        <div class="logo">
            <h1 class="name"><span>G</span>UNITA</h1>
        </div>
        <img src="/images/guest-profile.png" class="profile-pic">
        <h2 style="color:#7f7f7f">guest</h2>
        <button><a href="/login">Log in</a></button>
    </div>
    {{/if}}

    <!-- Feed -->
    <div class="feed">
        <div class="page-header">
            <h1>Edit Comment</h1>
            <p>Update your thoughts.</p>
        </div>

        <div class="create-post">
            <form action="/comment/{{comment._id}}/edit" method="POST">
                <div class="form-group">
                    <label>Comment</label>
                    <textarea name="text" rows="4" required>{{comment.text}}</textarea>
                </div>

                <div class="form-buttons">
                    <a href="/post/{{comment.post}}">
                        <button type="button" class="cancel-btn">Cancel</button>
                    </a>
                    <button type="submit" class="post-btn">Save Changes</button>
                </div>
            </form>

            <form action="/comment/{{comment._id}}/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this comment?');" style="margin-top:10px;">
                <button type="submit" class="cancel-btn" style="background:red; color:white;">Delete Comment</button>
            </form>
        </div>
    </div>

</div>
</body>
</html>