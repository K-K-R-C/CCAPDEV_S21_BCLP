<div class="comment reply">
    <div class="comment-header">
        <div class="comment-user-info">
            <img src="{{this.author.profilePic}}" class="profile-pic-small">
            <div>
                <strong><a href="/user/{{this.author.username}}">{{this.author.displayname}}</a></strong>
                <span class="comment-date">
                    {{formatDate this.createdAt}}
                    {{#if this.isEdited}}• edited{{/if}}
                </span>
            </div>
        </div>

        {{#if this.isOwner}}
        <div class="comment-actions">
            <a href="/comment/{{this._id}}/edit" class="owner-btn">Edit</a>

            <input type="checkbox" id="delete-comment-{{this._id}}" class="delete-toggle">
            <label for="delete-comment-{{this._id}}" class="owner-btn danger">Delete</label>

            <div class="delete-modal">
                <div class="delete-modal-content">
                    <h4>Delete Comment</h4>
                    <p>Are you sure you want to delete this comment?</p>
                    <div class="modal-actions">
                        <label for="delete-comment-{{this._id}}" class="light-btn">Cancel</label>
                        <form action="/comment/{{this._id}}/delete" method="POST">
                            <button type="submit" class="dark-btn">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {{/if}}
    </div>

    <p>{{this.text}}</p>

    {{#if @root.user}}
    <form action="/post/{{@root.post._id}}/comment" method="POST" class="reply-form">
        <input type="hidden" name="parentComment" value="{{this._id}}">
        <textarea name="text" placeholder="Reply..." rows="2" maxlength="500" required></textarea>
        <div class="form-buttons">
            <button type="submit" class="post-btn">Reply</button>
        </div>
    </form>
    {{/if}}

    {{#if this.replies.length}}
    <div class="replies">
        {{#each this.replies}}
            {{> commentPartial}}
        {{/each}}
    </div>
    {{/if}}
</div>