<!DOCTYPE html>
<html>
<head>
    <title>Post</title>
    <link rel="icon" href="/images/gunita-logo.png" type="image/png">

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/sidebar.css">
    <link rel="stylesheet" href="/css/posts.css">
    <script src="/js/main.js" defer></script>
</head>

<body>
    <div class="container">  

        <!-- Left Sidebar -->
        <!-- LOGGED IN VIEW -->
        {{#if user}}
        <div class="left-sidebar" id="loggedInContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="/images/{{user.profilePic}}" class="profile-pic" alt="Profile Pic">
            <h2><a href="/user/{{user.username}}" class="profile-link">{{user.username}}</a></h2>
            <p>@{{user.handle}}</p>

            <button>
                <a href="/" class="sidebar-btn">
                    <img src="/images/home-button.png" class="home-button" alt="Home">
                    Home
                </a>
            </button>

            <button>
                <a href="/create-post" class="sidebar-btn">
                    <img src="/images/new-post-button.png" class="new-post-button" alt="New Post">
                    New Post
                </a>
            </button> 
        </div>

        <!-- LOGGED OUT VIEW -->
        {{else}}
        <div class="left-sidebar" id="loggedOutContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="/images/guest-profile.png" class="profile-pic" alt="Profile Pic">
            <h2 style="color: #7f7f7f">guest</h2>
            <button>
              <a href="/register">
                Sign up
              </a>
            </button>

            <button>
              <a href="/login">
                Log in
              </a>
            </button>
        </div>
        {{/if}}

        <!-- Main Post Content -->
        <div class="single-post">  <!-- Opens .single-post -->
            <div class="post detailed-post">  <!-- Opens .post -->
                <div class="post-header">
                    <div class="user">
                        <img src="/images/{{post.authorProfilePic}}" class="profile-pic" alt="Profile Pic">
                        <a href="/user/{{post.author}}" class="profile-link">
                            <p>{{post.author}}</p>
                        </a>
                    </div>
                    <span class="post-date">{{post.date}}</span>
                </div>

                <div class="post-images">
                    {{#each post.images}}
                        <img src="/images/{{this}}" alt="Post Image">
                    {{/each}}
                </div>

                <div class="post-content">
                    <p><strong>{{post.title}}</strong></p>
                    <p>{{post.description}}</p>
                </div>

                <div class="post-footer">
                    <div class="interactions">
                        <button onclick="changeLike('{{post._id}}')">
                            <img src="/images/thumbs-up.png" class="icon">
                        </button>
                        <span class="counter">{{post.likes}}</span>

                        <button onclick="changeDislike('{{post._id}}')">
                            <img src="/images/thumbs-down.png" class="icon">
                        </button>
                        <span class="counter">{{post.dislikes}}</span>

                        <img src="/images/comment.png" class="icon">
                        <span class="counter">{{post.commentCount}}</span>
                    </div>

                    <div class="hashtags">
                        {{#each post.hashtags}}
                            <span>#{{this}}</span>
                        {{/each}}
                    </div>
                </div>

                <!-- Comments Section -->
                <div class="comments-section">  <!-- Opens .comments-section -->
                    <h3>Comments</h3>
                    <a href="/post/{{post._id}}/comment" class="add-comment-link">Add a Comment</a>

                    {{#each comments}}
                    <div class="comment">
                        <strong><a href="/user/{{this.author}}">{{this.author}}</a></strong>
                        <p>{{this.text}}</p>

                        {{#if this.replies}}
                        <div class="replies">
                            {{#each this.replies}}
                            <div class="comment">
                                <strong><a href="/user/{{this.author}}">{{this.author}}</a></strong>
                                <p>{{this.text}}</p>
                            </div>
                            {{/each}}
                        </div>
                        {{/if}}
                    </div>
                    {{/each}}

                </div>  <!-- Closes .comments-section -->
            </div>  <!-- Closes .post -->
        </div>  <!-- Closes .single-post -->

        <!-- Right Sidebar -->
        <div class="right-sidebar">  <!-- Opens .right-sidebar -->
            <!-- Search Bar -->
            <div class="searchbar">
                <form>
                    <img src="/images/search-icon.png" alt="Search" class="search-icon">
                    <input type="text" placeholder="Search...">
                </form>
            </div>

            <!-- Trending Section -->
            <div class="trending">
                <h3>Top 3 Trending</h3>
                <ul>
                    <li>#EntitledForeigners</li>
                    <li>#ValentinesDay</li>
                    <li>#HappySinglesDay</li>
                </ul>
            </div>

            <!-- Filters Section -->
            <div class="filters">
                <h3>Destination</h3>
                <div class="filter-list">
                    <label><input type="checkbox" checked> Luzon</label>
                    <label><input type="checkbox"> Visayas</label>
                    <label><input type="checkbox"> Mindanao</label>
                </div>

                <h3 class="section-gap">Travel Style</h3>
                <div class="filter-list">
                    <label><input type="checkbox" checked> Budget</label>
                    <label><input type="checkbox"> Family</label>
                    <label><input type="checkbox"> Backpacking</label>
                    <label><input type="checkbox"> Luxury</label>
                    <label><input type="checkbox"> Solo</label>
                    <button>Set Filters</button>
                </div>
            </div>
        </div>  <!-- Closes .right-sidebar -->

    </div>  <!-- Closes .container -->
</body>
</html>