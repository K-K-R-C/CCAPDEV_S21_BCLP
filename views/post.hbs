<!DOCTYPE html>
<html>
<head>
    <title>Post</title>
    <link rel="icon" href="/images/gunita-logo.png" type="image/png">

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/sidebar.css">
    <link rel="stylesheet" href="/css/posts.css">
    <script src="/js/main.js" defer></script>
</head>

<body>
    <div class="container">  

        <!-- Left Sidebar -->
        <!-- LOGGED IN VIEW -->
        {{#if user}}
        <div class="left-sidebar" id="loggedInContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="{{user.profilePic}}" class="profile-pic" alt="Profile Pic">
            <h2><a href="/user/{{user.username}}" class="profile-link">{{user.username}}</a></h2>
            <p>@{{user.handle}}</p>

            <button>
                <a href="/" class="sidebar-btn">
                    <img src="/images/home-button.png" class="home-button" alt="Home">
                    Home
                </a>
            </button>

            <button>
                <a href="/create-post" class="sidebar-btn">
                    <img src="/images/new-post-button.png" class="new-post-button" alt="New Post">
                    New Post
                </a>
            </button> 
        </div>

        <!-- LOGGED OUT VIEW -->
        {{else}}
        <div class="left-sidebar" id="loggedOutContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="/images/guest-profile.png" class="profile-pic" alt="Profile Pic">
            <h2 style="color: #7f7f7f">guest</h2>
            <button>
              <a href="/register">
                Sign up
              </a>
            </button>

            <button>
              <a href="/login">
                Log in
              </a>
            </button>
        </div>
        {{/if}}

        <!-- Main Post Content -->
        <div class="single-post">  <!-- Opens .single-post -->
            <div class="post detailed-post">  <!-- Opens .post -->
                <div class="post-header">
                    <div class="user">
                        <img src="{{post.author.profilePic}}" class="profile-pic" alt="Profile Pic">
                        <a href="/user/{{post.author.username}}" class="profile-link">
                            <p>{{post.author.username}}</p>
                        </a>
                    </div>
                    <span class="post-date">
                        {{formatDate post.createdAt}}
                        {{#if post.isEdited}}• edited{{/if}}
                    </span>
                </div>

                <div class="post-images">
                    {{#each post.images}}
                        <img src="{{this}}" alt="Post Image">
                    {{/each}}
                </div>

                <div class="post-content">
                    <p><strong>{{post.title}}</strong></p>
                    <p>{{post.body}}</p>
                </div>

                {{#if isOwner}}
                <div style="margin-top: 10px;">
                    <a href="/post/{{post._id}}/edit">
                        <button class="post-btn">Edit</button>
                    </a>

                    <form action="/post/{{post._id}}/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this post?');">
                        <button type="submit" class="cancel-btn" style="background:red; color:white;">
                            Delete
                        </button>
                    </form>
                </div>
                {{/if}}

                <div class="post-footer">
                    <div class="interactions">
                        <button class="like-btn" data-post-id="{{post._id}}">
                            <img src="/images/thumbs-up.png" class="icon">
                        </button>
                        <span class="counter">{{post.upvotes.length}}</span>

                        <button class="dislike-btn" data-post-id="{{post._id}}">
                            <img src="/images/thumbs-down.png" class="icon">
                        </button>
                        <span class="counter">{{post.downvotes.length}}</span>

                        <img src="/images/comment.png" class="icon">
                        <span class="counter">{{post.commentCount}}</span>
                    </div>

                    <div class="hashtags">
                        {{#each post.hashtags}}
                            <span>#{{this}}</span>
                        {{/each}}
                    </div>
                </div>

                <!-- Comments Section -->
                <div class="comments-section">
                    <h3>
                        {{#if post.commentCount}}
                            {{post.commentCount}} Comments
                        {{else}}
                            Be the first to comment!
                        {{/if}}
                    </h3>

                    {{#each comments}}
                        {{> commentPartial}}
                    {{/each}}
                </div>

                    <!-- INLINE COMMENT FORM -->
                    {{#if user}}
                    <div class="add-comment-section">
                        <h4>Add a Comment</h4>
                        <form action="/post/{{post._id}}/comment" method="POST">
                            <textarea name="text" placeholder="Share your thoughts..." rows="3" maxlength="500" required></textarea>
                            <div class="form-buttons">
                                <a href="/"><button type="button" class="cancel-btn">Cancel</button></a>
                                <button type="submit" class="post-btn">Post Comment</button>
                            </div>
                        </form>
                    </div>
                    {{else}}
                    <p class="login-prompt"><a href="/login">Log in to comment</a></p>
                    {{/if}}
                </div> <!-- Closes .comments -->
            </div>  <!-- Closes .post -->
        </div>  <!-- Closes .single-post -->

        <!-- Right Sidebar -->
        <div class="right-sidebar">
            <!-- Search Bar -->
            <div class="searchbar">
                <form method = "GET" id = "searchForm">
                    <img src="/images/search-icon.png" alt="Search" class="search-icon">
                    <input type="text" name ="search" placeholder="Search posts..." value="{{filters.search}}">
                    <button type="submit" style="display:none;"></button>
                </form>
            </div>

            <!-- Trending Section -->
            <div class="trending">
                <h3>Top 3 Trending</h3>
                <ul>
                    <li>#EntitledForeigners</li>
                    <li>#ValentinesDay</li>
                    <li>#HappySinglesDay</li>
                </ul>
            </div>

            <!-- Filters Section -->
            <div class="filters">
                <h3>Destination</h3>

                <form method="GET" id="filterForm">
                    <input type="hidden" name="search" value="{{filters.search}}">

                    <div class="filter-list">
                        <label><input type="radio" name="destination" value="all" {{#if (eq filters.destination 'all')}}checked{{/if}}> All</label>
                        <label><input type="radio" name="destination" value="Luzon" {{#if (eq filters.destination 'Luzon')}}checked{{/if}}> Luzon</label>
                        <label><input type="radio" name="destination" value="Visayas" {{#if (eq filters.destination 'Visayas')}}checked{{/if}}> Visayas</label>
                        <label><input type="radio" name="destination" value="Mindanao" {{#if (eq filters.destination 'Mindanao')}}checked{{/if}}> Mindanao</label>
                    </div>

                    <h3 class="section-gap">Travel Style</h3>
                    <div class="filter-list">
                        <label><input type="radio" name="travelStyle" value="all" {{#if (eq filters.travelStyle 'all')}}checked{{/if}}> All</label>
                        <label><input type="radio" name="travelStyle" value="Budget" {{#if (eq filters.travelStyle 'Budget')}}checked{{/if}}> Budget</label>
                        <label><input type="radio" name="travelStyle" value="Family" {{#if (eq filters.travelStyle 'Family')}}checked{{/if}}> Family</label>
                        <label><input type="radio" name="travelStyle" value="Backpacking" {{#if (eq filters.travelStyle 'Backpacking')}}checked{{/if}}> Backpacking</label>
                        <label><input type="radio" name="travelStyle" value="Luxury" {{#if (eq filters.travelStyle 'Luxury')}}checked{{/if}}> Luxury</label>
                        <label><input type="radio" name="travelStyle" value="Solo" {{#if (eq filters.travelStyle 'Solo')}}checked{{/if}}> Solo</label>
                    </div>

                    <button type="submit">Apply Filters</button>
                    <button type="button" class="clear-btn" onclick="clearAll()">Clear All</button>
                </form>
            </div>
        </div>
    </div>  <!-- Closes .container -->
</body>
</html>