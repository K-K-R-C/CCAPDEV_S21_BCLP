<!DOCTYPE html>
<html>
  <head>
    <title>Gunita</title>
    <link rel="icon" href="/images/gunita-logo.png" type="image/png">

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/posts.css">
    <link rel="stylesheet" href="/css/profile.css">
    <script src="/js/main.js" defer></script>
  </head>

  <body>
    <div class="container">

        <!-- Left Sidebar -->
        <!-- LOGGED IN VIEW -->
        {{#if user}}
        <div class="left-sidebar" id="loggedInContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="{{user.profilePic}}" class="profile-pic" alt="Profile Pic">
            <h2><a href="/user/{{user.username}}" class="profile-link">{{user.displayname}}</a></h2>
            <p>@{{user.username}}</p>

            <button>
                <a href="/" class="sidebar-btn">
                    <img src="/images/home-button.png" class="home-button" alt="Home">
                    Home
                </a>
            </button>

            <button>
                <a href="/create-post" class="sidebar-btn">
                    <img src="/images/new-post-button.png" class="new-post-button" alt="New Post">
                    New Post
                </a>
            </button> 
        </div>

        <!-- LOGGED OUT VIEW -->
        {{else}}
        <div class="left-sidebar" id="loggedOutContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="/images/guest-profile.png" class="profile-pic" alt="Profile Pic">
            <h2 style="color: #7f7f7f">guest</h2>
            <button>
              <a href="/register">
                Sign up
              </a>
            </button>

            <button>
              <a href="/login">
                Log in
              </a>
            </button>
        </div>
        {{/if}}

        <!-- CENTER COLUMN -->
        <section class="center-col">

          <!-- PROFILE HEADER CARD -->
          <div class="card profile-header">
             <div class="cover" style="background-image: url('{{profile.coverPic}}');"></div>
              <div class="profile-row">
                <a href="{{profile.profilePic}}">
                  <img src="{{profile.profilePic}}" alt="Profile Picture" class="avatar xl">
                </a>

                <div class="profile-meta">
                  <h2 class="profile-name">{{profile.displayname}}</h2>
                  <p class="profile-handle">@{{profile.username}}</p>
                  <p class="profile-location">{{profile.location}}</p>

                  <p class="bio">
                    {{profile.bio}}
                  </p>
                </div>

                <!-- PROFILE ACTIONS -->
                <div class="profile-actions">
                  {{#if user}}
                    {{#if isOwner}}
                      <!-- Owner only -->
                      <a href="/edit-profile">
                        <button class="dark-btn">Edit profile</button>
                      </a>
                      <button type="button" class="dark-btn" id="logoutButton">Log out</button>
                    {{/if}}
                  {{else}}
                    <!-- Guest sees: Login -->
                    <a href="/login">
                      <button class="dark-btn">Log in</button>
                    </a>
                  {{/if}}
                </div>
              </div>
          </div>

          <!-- POST CARD -->
          {{#each posts}}
          <a href="/post/{{this._id}}" class="post-link">
            <div class="post">

                <div class="post-header">
                    <div class="user">
                        <img src="{{this.author.profilePic}}" class="profile-pic" alt="Profile Pic">
                        <p>{{this.author.username}}</p>
                    </div>
                    <span class="post-date">
                        {{formatDate this.createdAt}}
                        {{#if this.isEdited}}• edited{{/if}}
                    </span>
                </div>

                <div class="post-images">
                    {{#each this.images}}
                    <img src="{{this}}" alt="Post Image">
                    {{/each}}
                </div>

                <div class="post-content">
                    <p><strong>{{this.title}}</strong></p>
                    <p>{{this.body}}</p>
                </div>

                <div class="post-footer">
                    <div class="interactions">
                        <button class="like-btn" data-post-id="{{this._id}}">
                            <img src="/images/thumbs-up.png" class="icon">
                        </button>
                        <span class="counter">{{this.upvotes.length}}</span>

                        <button class="dislike-btn" data-post-id="{{this._id}}">
                            <img src="/images/thumbs-down.png" class="icon">
                        </button>
                        <span class="counter">{{this.downvotes.length}}</span>

                        <img src="/images/comment.png" class="icon">
                        <span class="counter">{{this.commentCount}}</span>
                    </div>

                    <div class="hashtags">
                        {{#each this.hashtags}}
                        <span>#{{this}}</span>
                        {{/each}}
                    </div>
                </div>

            </div>
          </a>
          {{/each}}

          <!-- RECENT COMMENTS -->
          <div class="profile-section">
            <h3 class="section-title">Recent Comments</h3>

            {{#each comments}}
            <a href="/post/{{this.post._id}}" class="comment-card">
              <div class="comment-top">
                <div class="comment-context">
                  On: <strong>{{this.post.title}}</strong> 
                  by <span class="comment-author">@{{this.author.username}}</span>
                </div>
                <span class="comment-time">
                  {{formatDate this.createdAt}}
                  {{#if this.isEdited}}• edited{{/if}}
                </span>
              </div>
              <p class="comment-text">
                {{this.text}}
              </p>
            </a>
            {{/each}}
          </div>

        </section>

        <!-- RIGHT SIDEBAR -->
        <div class="right-sidebar">
            <div class="searchbar">
                <form>
                    <img src="../images/search-icon.png" alt="Search" class="search-icon">
                    <input type="text" placeholder="Search...">
                </form>
            </div>

            <div class="trending">
                <h3>Hashtags</h3>
                <ul>
                    {{#each trendingHashtags}}
                        <li>
                            <a href="/?search={{this}}">
                                #{{this}}
                            </a>
                        </li>
                    {{/each}}
                </ul>
            </div>
        </div>
    </div>
  </body>
</html>
