<!DOCTYPE html>
<html>
  <head>
    <title>Gunita</title>
    <link rel="icon" href="/images/gunita-logo.png" type="image/png">

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/posts.css">
    <link rel="stylesheet" href="/css/profile.css">
    <script src="/js/main.js" defer></script>
  </head>

  <body>
    <div class="container">

        <!-- Left Sidebar -->
        <!-- LOGGED IN VIEW -->
        {{#if user}}
        <div class="left-sidebar" id="loggedInContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="/images/{{user.profilePic}}" class="profile-pic" alt="Profile Pic">
            <h2><a href="/user/{{user.username}}" class="profile-link">{{user.username}}</a></h2>
            <p>@{{user.handle}}</p>

            <button>
                <a href="/" class="sidebar-btn">
                    <img src="/images/home-button.png" class="home-button" alt="Home">
                    Home
                </a>
            </button>

            <button>
                <a href="/create-post" class="sidebar-btn">
                    <img src="/images/new-post-button.png" class="new-post-button" alt="New Post">
                    New Post
                </a>
            </button> 
        </div>

        <!-- LOGGED OUT VIEW -->
        {{else}}
        <div class="left-sidebar" id="loggedOutContainer">
            <!-- Logo -->
            <div class="logo">
                <h1 class="name"><span>G</span>UNITA</h1>
            </div>

            <img src="/images/guest-profile.png" class="profile-pic" alt="Profile Pic">
            <h2 style="color: #7f7f7f">guest</h2>
            <button>
              <a href="/register">
                Sign up
              </a>
            </button>

            <button>
              <a href="/login">
                Log in
              </a>
            </button>
        </div>
        {{/if}}

        <!-- CENTER COLUMN -->
        <section class="center-col">

          <!-- PROFILE HEADER CARD -->
          <div class="card profile-header">
              <div class="cover"></div>

              <div class="profile-row">
                <a href="/images/{{profile.profilePic}}">
                  <img src="/images/{{profile.profilePic}}" alt="Profile Picture" class="avatar xl">
                </a>

                <div class="profile-meta">
                  <h2 class="profile-name">{{profile.username}}</h2>
                  <p class="profile-handle">@{{profile.handle}}</p>
                  <p class="profile-location">{{profile.location}}</p>

                  <p class="stats">
                    <strong>{{profile.followers}}</strong> followers
                    <span class="dot">•</span>
                    <strong>{{profile.following}}</strong> following
                    <span class="dot">•</span>
                    <strong>{{posts.length}}</strong> posts
                  </p>

                  <p class="bio">
                    {{profile.bio}}
                  </p>
                </div>

                <!-- PROFILE ACTIONS (LOGGED OUT VERSION) -->
                <div class="profile-actions">
                  {{#unless isOwner}}
                    <a href="/user/{{profile.username}}">
                      <button class="dark-btn">Follow</button>
                    </a>
                  {{/unless}}
                </div>
              </div>
          </div>

          <!-- POST CARD -->
          {{#each posts}}
          <a href="/post/{{this._id}}" class="post-link">
            <div class="post">

                <div class="post-header">
                    <div class="user">
                        <img src="/images/{{this.authorProfilePic}}" class="profile-pic" alt="Profile Pic">
                        <p>{{this.author}}</p>
                    </div>
                    <span class="post-date">{{this.date}}</span>
                </div>

                <div class="post-images">
                    {{#each this.images}}
                    <img src="/images/{{this}}" alt="Post Image">
                    {{/each}}
                </div>

                <div class="post-content">
                    <p><strong>{{this.title}}</strong></p>
                    <p>{{this.description}}</p>
                </div>

                <div class="post-footer">
                    <div class="interactions">
                        <button onclick="changeLike('{{this._id}}')">
                            <img src="/images/thumbs-up.png" class="icon">
                        </button>
                        <span class="counter">{{this.likes}}</span>

                        <button onclick="changeDislike('{{this._id}}')">
                            <img src="/images/thumbs-down.png" class="icon">
                        </button>
                        <span class="counter">{{this.dislikes}}</span>

                        <img src="/images/comment.png" class="icon">
                        <span class="counter">{{this.commentCount}}</span>
                    </div>

                    <div class="hashtags">
                        {{#each this.hashtags}}
                        <span>#{{this}}</span>
                        {{/each}}
                    </div>
                </div>

            </div>
          </a>
          {{/each}}

          <!-- RECENT COMMENTS -->
          <div class="profile-section">
            <h3 class="section-title">Recent Comments</h3>

            {{#each comments}}
            <a href="/post/{{this.postId}}" class="comment-card">
              <div class="comment-top">
                <div class="comment-context">
                  On: <strong>{{this.postTitle}}</strong> 
                  by <span class="comment-author">@{{this.author}}</span>
                </div>
                <span class="comment-time">{{this.date}}</span>
              </div>
              <p class="comment-text">
                {{this.text}}
              </p>
            </a>
            {{/each}}
          </div>

        </section>

        <!-- RIGHT SIDEBAR -->
        <div class="right-sidebar">
            <div class="searchbar">
                <form>
                    <img src="../images/search-icon.png" alt="Search" class="search-icon">
                    <input type="text" placeholder="Search...">
                </form>
            </div>

            <div class="trending">
                <h3>Top 3 Trending</h3>
                <ul>
                    <li>#EntitledForeigners</li>
                    <li>#ValentinesDay</li>
                    <li>#HappySinglesDay</li>
                </ul>
            </div>

            <div class="card filters">
                <h3>Destination</h3>
                <div class="filter-list">
                  <label><input type="checkbox" checked> Luzon</label>
                  <label><input type="checkbox"> Visayas</label>
                  <label><input type="checkbox"> Mindanao</label>
                </div>

                <h3 class="section-gap">Travel Style</h3>
                <div class="filter-list">
                  <label><input type="checkbox" checked> Budget</label>
                  <label><input type="checkbox"> Family</label>
                  <label><input type="checkbox"> Backpacking</label>
                  <label><input type="checkbox"> Luxury</label>
                  <label><input type="checkbox"> Solo</label>
                </div>

                <button>Set Filters</button>
            </div>
        </div>

    </div>
  </body>
</html>
